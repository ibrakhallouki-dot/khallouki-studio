{
  "version": 2,
  "builds": [
    {
      "src": "packages/server/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "packages/web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "packages/server/src/index.ts"
    },
    {
      "source": "/trpc/(.*)",
      "destination": "packages/server/src/index.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "packages/server/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "packages/web/$1"
    }
  ]
}
